# lusterpass configuration
# Copy to .lusterpass.yaml in your project root and customize.
# This file contains NO secret values — safe to commit to git.

project: myapp

# Common: shared values used everywhere.
# Pull and load with:
#   lusterpass pull
#   eval "$(lusterpass env)"
common:
  vars:
    APP_NAME: myapp
    LOG_FORMAT: json
    TZ: UTC
  secrets:
    # Format: ENV_VAR_NAME: bitwarden-reference-name
    DATABASE_URL: db-url--myapp
    OPENAI_API_KEY: openai-key--myapp

# Per-environment profiles (optional)
# Uncomment and customize if you need to differentiate dev / staging / prod.
# Profile values override common values for the same key. Use:
#   lusterpass pull --profile dev
#   eval "$(lusterpass env --profile dev)"
#
# profiles:
#   dev:
#     vars:
#       LOG_LEVEL: debug
#       APP_URL: http://localhost:3000
#     secrets:
#       DATABASE_URL: db-url--myapp--dev
#
#   staging:
#     vars:
#       LOG_LEVEL: info
#       APP_URL: https://staging.myapp.com
#     secrets:
#       DATABASE_URL: db-url--myapp--staging
#
#   prod:
#     vars:
#       LOG_LEVEL: warn
#       APP_URL: https://myapp.com
#     secrets:
#       DATABASE_URL: db-url--myapp--prod
